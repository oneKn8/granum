# Google Cloud — granum-2026 under shifatislamsanto764@gmail.com
# Billing: 01D7E1-9DABE7-254A06 (OPEN). APIs enabled: aiplatform, run,
# cloudbuild, artifactregistry, secretmanager, cloudscheduler.
GOOGLE_CLOUD_PROJECT=granum-2026
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Gemini — verified 2026-05-27 against Vertex AI for granum-2026.
# `gemini-3-pro` was DISCONTINUED March 2026; use the current canonical names.
# Primary reasoning model (agent + LLM-as-judge):
GEMINI_MODEL=gemini-3.1-pro-preview
# Fast/cheap model for high-volume calls (mutation proposer, citation extraction):
GEMINI_MODEL_FAST=gemini-3.5-flash
# Recommended Vertex location: `global` (where both models above are accessible).
# Set GOOGLE_CLOUD_LOCATION=global below if you hit regional 404s.

# Phoenix
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=granum

# Granum-specific
GRANUM_CELL=aetna_cardiac
GRANUM_POPULATION_SIZE=5
GRANUM_TOURNAMENT_SIZE=3
GRANUM_MUTATION_RATE=0.15
GRANUM_DB_PATH=./granum.db

# Web frontend (web/) — Terminal C
# Set USE_REAL_API to "true" to fetch live data from the Cloud Run service
# (per docs/api-contract.md). Default false uses deterministic mock data.
NEXT_PUBLIC_USE_REAL_API=false
NEXT_PUBLIC_API_BASE_URL=https://granum-xxxxx-uc.a.run.app
